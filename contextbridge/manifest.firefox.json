{
  "manifest_version": 3,
  "name": "ContextBridge",
  "version": "1.0.0",
  "description": "Transfer AI chat conversations between Claude, ChatGPT, and Gemini seamlessly.",
  "browser_specific_settings": {
    "gecko": {
      "id": "contextbridge@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ContextBridge"
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "utils/browser-polyfill.js",
        "content/readers/claude-reader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": [
        "utils/browser-polyfill.js",
        "content/readers/chatgpt-reader.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "utils/browser-polyfill.js",
        "content/readers/gemini-reader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings/settings.html",
  "web_accessible_resources": [
    {
      "resources": [
        "content/injectors/claude-injector.js",
        "content/injectors/chatgpt-injector.js",
        "content/injectors/gemini-injector.js",
        "utils/browser-polyfill.js"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}